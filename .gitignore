# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 실제 값이 담긴 파일만 제외, example은 커밋 허용
.env*.local
.env.local
.env.production
.env.development
# .env.local.example 은 커밋 허용 (주석 해제 필요 없음)

# Claude Code 로컬 설정
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
